{
  "name": "@tracekit/vue",
  "version": "0.1.1",
  "description": "TraceKit Vue Integration - Error capture and navigation breadcrumbs for Vue 3",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "@tracekit/browser": "^0.1.1",
    "vue": ">=3.3.0"
  },
  "optionalDependencies": {
    "vue-router": ">=4.0.0"
  },
  "devDependencies": {
    "jsdom": "^28.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^3.0.0",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Tracekit-Dev/vue"
  },
  "keywords": [
    "tracekit",
    "vue",
    "error-tracking",
    "observability",
    "breadcrumbs"
  ]
}
